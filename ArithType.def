#ifndef ARITH
#define ARITH(T, BITSIZE, REPR)
#endif

// Unsigned types
ARITH(BOOL, 1, "bool")
ARITH(CHAR_U, 8, "char") // For char which is unsigned.
ARITH(UNSIGNED_CHAR, 8, "unsigned char")
ARITH(UNSIGNED_SHORT, 16, "unsigned short")
ARITH(UNSIGNED_INT, 32, "unsigned int")
ARITH(UNSIGNED_LONG, 64, "unsigned long")
ARITH(UNSIGNED_LONG_LONG, 64, "unsigned long long")

// Signed types
ARITH(CHAR_S, 8, "char") // For char which is signed.
ARITH(SIGNED_CHAR, 8, "signed char")
ARITH(SHORT, 16, "short")
ARITH(INT, 32, "int")
ARITH(LONG, 64, "long")
ARITH(LONG_LONG, 64, "long long")

// Floating point types
ARITH(FLOAT, 32, "float")
ARITH(DOUBLE, 64, "double")
ARITH(LONG_DOUBLE, 64, "long double")

#undef ARITH